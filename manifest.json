{
  "manifest_version": 3,
  "name": "Account & Subscription Shortcuts",
  "version": "0.3.4",
  "description": "Quick links to official account & subscription pages. Opens in a new tab. Local-only: language and shortcuts you add.",
  "permissions": ["storage", "windows"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Account & Subscription Shortcuts",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
